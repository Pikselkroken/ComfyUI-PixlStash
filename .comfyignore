venv/
.ruff_cache/

# Security-regression tests — run in dev/CI, not needed by ComfyUI users at
# runtime. Keeping them out of the artifact also stops the registry yara_scan
# from flagging the deliberately-hostile test fixtures (injection payloads).
tests/
